{
  "openapi": "3.0.3",
  "info": {
    "title": "Sweet Bakery Online Store",
    "description": "API for a bakery e-commerce store selling cakes, pastries, and custom orders",
    "version": "1.0.0"
  },
  "paths": {
    "/products": {
      "get": {
        "operationId": "listProducts",
        "summary": "List all products in the bakery catalog",
        "tags": ["products"],
        "parameters": [
          {
            "name": "category",
            "in": "query",
            "schema": { "type": "string", "enum": ["cakes", "pastries", "bread", "custom"] },
            "description": "Filter by product category"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 20 },
            "description": "Number of results per page"
          }
        ],
        "responses": {
          "200": {
            "description": "List of products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Product" }
                }
              }
            }
          }
        }
      }
    },
    "/products/{productId}": {
      "get": {
        "operationId": "getProductDetails",
        "summary": "Get full details for a specific product",
        "tags": ["products"],
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Product identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Product details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Product" }
              }
            }
          }
        }
      }
    },
    "/cart": {
      "get": {
        "operationId": "getCart",
        "summary": "Get current shopping cart contents",
        "tags": ["cart"],
        "responses": {
          "200": {
            "description": "Cart contents",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Cart" }
              }
            }
          }
        }
      }
    },
    "/cart/items": {
      "post": {
        "operationId": "addToCart",
        "summary": "Add a product to the shopping cart",
        "tags": ["cart"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["product_id", "quantity"],
                "properties": {
                  "product_id": {
                    "type": "string",
                    "description": "Product identifier"
                  },
                  "quantity": {
                    "type": "integer",
                    "description": "Number of items to add",
                    "default": 1
                  },
                  "variant_id": {
                    "type": "string",
                    "description": "Product variant (size, flavor)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Item added to cart",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Cart" }
              }
            }
          }
        }
      }
    },
    "/checkout": {
      "post": {
        "operationId": "submitCheckout",
        "summary": "Initiate checkout - returns payment URL for confirmation",
        "tags": ["checkout"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["shipping_address", "email"],
                "properties": {
                  "shipping_address": {
                    "type": "object",
                    "description": "Delivery address"
                  },
                  "email": {
                    "type": "string",
                    "description": "Customer email for confirmation"
                  },
                  "shipping_method": {
                    "type": "string",
                    "description": "Selected shipping method"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Checkout session created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "checkout_id": { "type": "string" },
                    "payment_url": { "type": "string" },
                    "total": { "type": "number" },
                    "currency": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/orders/{orderId}": {
      "get": {
        "operationId": "getOrderStatus",
        "summary": "Get order status and tracking info",
        "tags": ["orders"],
        "parameters": [
          {
            "name": "orderId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Order identifier"
          }
        ],
        "responses": {
          "200": {
            "description": "Order details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Order" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "number" },
          "currency": { "type": "string" },
          "category": { "type": "string" },
          "in_stock": { "type": "boolean" },
          "images": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Cart": {
        "type": "object",
        "properties": {
          "cart_id": { "type": "string" },
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/CartItem" } },
          "item_count": { "type": "integer" },
          "subtotal": { "type": "number" },
          "currency": { "type": "string" }
        }
      },
      "CartItem": {
        "type": "object",
        "properties": {
          "product_id": { "type": "string" },
          "product_name": { "type": "string" },
          "quantity": { "type": "integer" },
          "unit_price": { "type": "number" }
        }
      },
      "Order": {
        "type": "object",
        "properties": {
          "order_id": { "type": "string" },
          "status": { "type": "string" },
          "items": { "type": "array", "items": { "$ref": "#/components/schemas/CartItem" } },
          "total": { "type": "number" },
          "tracking_number": { "type": "string" }
        }
      }
    }
  }
}
